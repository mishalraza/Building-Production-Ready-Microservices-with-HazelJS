{
  "name": "hazeljs-microservices",
  "version": "1.0.0",
  "description": "Building Production-Ready Microservices with HazelJS",
  "main": "dist/app.module.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.module.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.module.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@hazeljs/discovery": "^0.3.1",
    "@hazeljs/resilience": "^0.3.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
